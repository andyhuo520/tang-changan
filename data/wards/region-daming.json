    "sources": ["《唐两京城坊考》卷一", "《长安志》卷六", "《大明宫遗址考古发掘报告》中国社会科学院考古研究所"],
    "famousPeople": ["唐太宗", "武则天", "唐玄宗", "杨贵妃", "李白", "万国使节"]
  },
